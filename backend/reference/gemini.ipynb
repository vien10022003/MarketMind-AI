   "source": [
    "from google import genai\n",
    "model = [\"gemini-2.5-flash-lite\", \"gemini-3.1-flash-lite-preview\"]\n",
    "client = genai.Client()\n",
    "\n",
    "response = client.models.generate_content(\n",
    "    model=model[0],\n",
    "    contents=\"Explain how AI works in a few words\",\n",
    ")\n",
    "\n",
    "print(response.text)"
   ]
  }
