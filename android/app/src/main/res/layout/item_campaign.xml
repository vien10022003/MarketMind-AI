<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_campaign_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="8dp"
    android:background="@drawable/rounded_bg"
    android:elevation="2dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        android:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?attr/colorSurface">

            <!-- Header with ID and Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎬"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_campaign_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Campaign ID"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_campaign_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ Đang Chờ"
                    android:textSize="12sp"
                    android:textColor="#F39C12"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/rounded_bg"
                    android:backgroundTint="#F39C1226" />
            </LinearLayout>

            <!-- Date -->
            <TextView
                android:id="@+id/tv_campaign_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="17/05/2026 10:30"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- Stats -->
            <TextView
                android:id="@+id/tv_campaign_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="12/15 đã đăng | 2 lỗi"
                android:textColor="?attr/colorOnBackground"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
