<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_campaign_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/rounded_bg"
    android:elevation="0dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="?attr/colorSurface"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header with ID and Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_campaign"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tv_campaign_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Campaign ID"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_campaign_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang Chờ"
                    android:textSize="12sp"
                    android:textColor="#F39C12"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/rounded_bg"
                    android:backgroundTint="#F39C1226" />
            </LinearLayout>

            <!-- Date -->
            <TextView
                android:id="@+id/tv_campaign_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="17/05/2026 10:30"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- Stats -->
            <TextView
                android:id="@+id/tv_campaign_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="12/15 đã đăng | 2 lỗi"
                android:textColor="?attr/colorOnBackground"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
