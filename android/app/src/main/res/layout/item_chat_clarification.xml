<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp">

    <!-- Clarification card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_clarification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cần làm rõ thêm..."
                android:textColor="@color/accent_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Questions -->
            <LinearLayout
                android:id="@+id/ll_questions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Input fields container (dynamically populated) -->
            <LinearLayout
                android:id="@+id/ll_input_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_clarification_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Hủy"
                    android:background="@drawable/bg_button_secondary"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_clarification_submit"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Gửi"
                    android:background="@drawable/bg_button_primary"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
