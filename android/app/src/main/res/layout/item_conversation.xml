<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Chat icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <!-- Conversation title -->
        <TextView
            android:id="@+id/tv_conversation_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btn_delete_conversation"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Xóa"
            android:scaleType="centerInside"
            android:tint="@color/text_tertiary" />

    </LinearLayout>

    <!-- Preview row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <!-- Message preview -->
        <TextView
            android:id="@+id/tv_conversation_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tv_conversation_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bg_surface_light"
        android:layout_marginTop="12dp" />

</LinearLayout>
