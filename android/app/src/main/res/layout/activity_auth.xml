<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Spacer -->
        <View
            android:layout_width="1dp"
            android:layout_height="48dp" />

        <!-- Logo Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MarketMind AI"
            android:textColor="@color/accent_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Auth Title -->
        <TextView
            android:id="@+id/tv_auth_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nghiên cứu thị trường · Phân tích đối thủ\nChiến lược marketing — tất cả bằng AI"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp" />

        <!-- Username Field -->
        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/username"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Password Field -->
        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/password"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Confirm Password Field (Register mode) -->
        <EditText
            android:id="@+id/et_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/confirm_password"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Full Name Field (Register mode) -->
        <EditText
            android:id="@+id/et_full_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/full_name"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"
            android:visibility="gone" />

        <!-- Error Text (dynamic) -->
        <TextView
            android:id="@+id/tv_auth_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Submit Button -->
        <Button
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/login"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <!-- Divider with "hoặc" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="12dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/bg_surface_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  hoặc  "
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/bg_surface_light" />

        </LinearLayout>

        <!-- Google Sign-In Button -->
        <Button
            android:id="@+id/btn_google_signin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔑 Đăng nhập với Google"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:layout_marginBottom="24dp" />

        <!-- Toggle Mode Text -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_toggle_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có tài khoản? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_toggle_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng ký"
                android:background="?attr/selectableItemBackground"
                android:textColor="@color/accent_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
