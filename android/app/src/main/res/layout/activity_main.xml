<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_primary">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/bg_surface"
            android:elevation="4dp"
            app:title="MarketMind AI"
            app:subtitle="🔬 Trợ lý nghiên cứu thị trường"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_secondary" />

        <!-- Welcome Hero (shown when no messages) -->
        <ScrollView
            android:id="@+id/layout_welcome_hero"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp">

                <!-- Spacer -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp" />

                <!-- Rocket Icon -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚀"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp" />

                <!-- App Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MarketMind AI"
                    android:textColor="@color/accent_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Tagline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nghiên cứu thị trường · Phân tích đối thủ\nChiến lược marketing — tất cả bằng AI"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="32dp" />

                <!-- Feature Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <!-- Feature 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_suggestion_chip"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nghiên cứu"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Feature 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_suggestion_chip"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chiến lược"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Feature 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_suggestion_chip"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marketing"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Suggestion section title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Gợi ý câu hỏi"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Suggestion Chips -->
                <Button
                    android:id="@+id/chip_1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📊 Nghiên cứu thị trường trà sữa tại Việt Nam"
                    android:background="@drawable/bg_suggestion_chip"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <Button
                    android:id="@+id/chip_2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🎯 Phân tích đối thủ ngành thương mại điện tử"
                    android:background="@drawable/bg_suggestion_chip"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <Button
                    android:id="@+id/chip_3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📈 Xu hướng marketing 2026 cho startup"
                    android:background="@drawable/bg_suggestion_chip"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <Button
                    android:id="@+id/chip_4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="💡 Lập chiến lược quảng cáo cho sản phẩm mới"
                    android:background="@drawable/bg_suggestion_chip"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </ScrollView>

        <!-- Chat Messages RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_messages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:background="@color/bg_primary"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bg_surface_light" />

        <!-- Input Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_surface"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- EditText -->
            <EditText
                android:id="@+id/et_message_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập câu hỏi của bạn..."
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:minHeight="44dp"
                android:layout_marginEnd="8dp" />

            <!-- Send Button -->
            <Button
                android:id="@+id/btn_send"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="➤"
                android:background="@drawable/bg_button_send"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Navigation Drawer -->
    <FrameLayout
        android:id="@+id/drawer_content"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/bg_surface" />

</androidx.drawerlayout.widget.DrawerLayout>