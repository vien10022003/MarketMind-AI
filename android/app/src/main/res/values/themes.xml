<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Material 3 Dark -->
    <style name="Base.Theme.MarketMindAI" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorTertiary">@color/accent_tertiary</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.MarketMindAI" parent="Base.Theme.MarketMindAI" />
</resources>